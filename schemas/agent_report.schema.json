{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.agentminds.dev/schemas/agent_report.schema.json",
  "title": "AgentMinds Reporting Profile (ARP) v1.1",
  "description": "Wire format for agent reports, warnings, learned patterns, recommendations and skill manifests. See docs/AGENT_REPORTING_PROFILE.md. ARP is a profile built on Sentry + OTel GenAI + MCP + Claude Skills + AGNTCY OASF; it is NOT a competing standard.",
  "type": "object",
  "required": ["agent", "report"],
  "additionalProperties": true,

  "properties": {
    "arp_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$",
      "description": "Semver of the ARP profile the sender targets. Defaults to latest minor of same major."
    },
    "ars_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$",
      "description": "Legacy alias for arp_version (pre-rename). Accepted for backwards compatibility; prefer arp_version on new payloads."
    },
    "agent": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9_-]*$",
      "description": "Stable agent name. Lowercase, snake/kebab case."
    },
    "site_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "Stable site identifier. May be set by the transport layer if absent in body."
    },
    "session_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Optional session/run identifier — correlates a sequence of agent invocations within one logical workflow. Compatible with LangSmith Threads and OpenInference session.id semantics."
    },
    "user_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Optional opaque user identifier (NOT PII — collectors should hash or pseudonymise upstream). Maps to OpenInference user.id."
    },
    "conversation_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Optional conversation/thread identifier. Alias of OTel gen_ai.conversation.id; multi-turn agent flows MAY use this to group reports."
    },
    "_meta": {
      "type": "object",
      "additionalProperties": true,
      "description": "ARP §2.1 (v1.1): vendor extension envelope using reverse-DNS namespacing (e.g. com.agentminds.*, io.agentminds.*). MCP-aligned. Open by design; collectors MUST ignore unknown keys. Reserved second-label namespaces: agentminds.*, arp.*."
    },
    "report":       { "$ref": "#/$defs/Report" },
    "memory":       { "$ref": "#/$defs/Memory" },
    "telemetry":    { "$ref": "#/$defs/Telemetry" },
    "project_info": { "$ref": "#/$defs/ProjectInfo" },
    "schema": {
      "type": "object",
      "properties": {
        "name":    { "type": "string" },
        "version": { "type": "string" }
      }
    }
  },

  "$defs": {
    "Severity": {
      "type": "string",
      "enum": ["fatal", "error", "warning", "info", "debug"]
    },
    "WarningSeverity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low", "info"]
    },
    "WarningStatus": {
      "type": "string",
      "enum": ["unresolved", "resolved", "ignored", "muted"],
      "default": "unresolved"
    },
    "PatternStatus": {
      "type": "string",
      "enum": ["active", "solved", "obsolete"],
      "default": "active"
    },
    "RecommendationStatus": {
      "type": "string",
      "enum": ["open", "applied", "dismissed"],
      "default": "open"
    },
    "Priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"]
    },
    "Effort": {
      "type": "string",
      "enum": ["trivial", "small", "medium", "large"]
    },
    "Impact": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"]
    },
    "Category": {
      "type": "string",
      "enum": [
        "performance", "security", "content", "seo",
        "quality", "compliance", "infra", "general"
      ]
    },
    "Fingerprint": {
      "description": "ARP fingerprint identity. Either a single lowercase hex SHA-256 string (canonical ARP form), or an array of strings with optional `{{ default }}` placeholder (Sentry-aligned form, v1.1+). Collectors MUST accept either; producers SHOULD pick one form per payload.",
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "Canonical ARP — lowercase hex SHA-256 (64 chars)."
        },
        {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "description": "Sentry-aligned array form — segments concatenated server-side. May include the literal `{{ default }}` placeholder at any position to inherit the SDK's default fingerprint."
        }
      ]
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 UTC timestamp."
    },

    "Score": {
      "description": "ARP §3.5 (v1.1): evaluation score primitive. Lineage: Langfuse Score model + LangSmith Feedback. Lets collectors carry NUMERIC / CATEGORICAL / BOOLEAN evaluation outcomes attached to warnings, patterns, or runs without overloading Recommendation.confidence.",
      "type": "object",
      "required": ["key", "data_type", "value"],
      "additionalProperties": true,
      "properties": {
        "fingerprint":  { "$ref": "#/$defs/Fingerprint" },
        "key":          { "type": "string", "minLength": 1, "description": "Short stable identifier, e.g. 'hallucination_check'." },
        "data_type":    { "type": "string", "enum": ["numeric", "categorical", "boolean"], "description": "Closed enum — keep this small, no vendor extensions." },
        "value":        { "description": "Number for data_type=numeric, string for categorical, boolean for boolean.", "oneOf": [{ "type": "number" }, { "type": "string" }, { "type": "boolean" }] },
        "comment":      { "type": "string", "description": "Optional long-form rationale." },
        "name":         { "type": "string", "description": "Human-readable label." },
        "warning_fingerprints": { "type": "array", "items": { "$ref": "#/$defs/Fingerprint" } },
        "pattern_fingerprints": { "type": "array", "items": { "$ref": "#/$defs/Fingerprint" } },
        "compared_to_baseline_id": { "type": "string", "description": "Optional baseline run identifier for comparative scoring." },
        "_meta":        { "type": "object", "additionalProperties": true }
      }
    },

    "Report": {
      "type": "object",
      "required": ["summary"],
      "additionalProperties": true,
      "properties": {
        "severity": { "$ref": "#/$defs/Severity" },
        "summary":  { "type": "string", "minLength": 1 },
        "score":    { "type": "number", "minimum": 0, "maximum": 100, "description": "Optional 0-100 health score for the agent run." },
        "metrics":  { "type": "object", "additionalProperties": true },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/Warning" }
        },
        "recommendations": {
          "type": "array",
          "items": { "$ref": "#/$defs/Recommendation" }
        },
        "scores": {
          "type": "array",
          "items": { "$ref": "#/$defs/Score" },
          "description": "ARP §3.5 (v1.1): evaluation scores attached to this report. Use Score for typed eval outcomes; the legacy `report.score` 0-100 health number is for one-off summaries only."
        },
        "_meta":    { "type": "object", "additionalProperties": true }
      }
    },

    "Warning": {
      "type": "object",
      "required": ["message"],
      "additionalProperties": true,
      "properties": {
        "fingerprint": { "$ref": "#/$defs/Fingerprint" },
        "message":     { "type": "string", "minLength": 1 },
        "level":       { "$ref": "#/$defs/Severity" },
        "severity":    { "$ref": "#/$defs/WarningSeverity" },
        "status":      { "$ref": "#/$defs/WarningStatus" },
        "first_seen":  { "$ref": "#/$defs/Timestamp" },
        "last_seen":   { "$ref": "#/$defs/Timestamp" },
        "count":       { "type": "integer", "minimum": 1 },
        "category":    { "$ref": "#/$defs/Category" },
        "tags":        { "type": "object", "additionalProperties": { "type": "string" } },
        "evidence":    { "type": "object", "additionalProperties": true },
        "_meta":       { "type": "object", "additionalProperties": true }
      }
    },

    "Recommendation": {
      "type": "object",
      "required": ["title"],
      "additionalProperties": true,
      "properties": {
        "fingerprint":  { "$ref": "#/$defs/Fingerprint" },
        "title":        { "type": "string", "minLength": 1 },
        "details":      { "type": "string" },
        "priority":     { "$ref": "#/$defs/Priority" },
        "category":     { "$ref": "#/$defs/Category" },
        "warning_fingerprints": {
          "type": "array",
          "items": { "$ref": "#/$defs/Fingerprint" }
        },
        "effort":       { "$ref": "#/$defs/Effort" },
        "confidence":   { "type": "number", "minimum": 0, "maximum": 1 },
        "code_snippet": { "type": "string" },
        "source_rule":  { "type": "string" },
        "status":       { "$ref": "#/$defs/RecommendationStatus" },
        "_meta":        { "type": "object", "additionalProperties": true }
      }
    },

    "Memory": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "learned_patterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/Pattern" }
        },
        "recurring_issues": {
          "type": "array",
          "items": { "$ref": "#/$defs/Warning" }
        },
        "total_runs":     { "type": "integer", "minimum": 0 },
        "schema_version": { "type": "string" },
        "_meta":          { "type": "object", "additionalProperties": true }
      }
    },

    "Pattern": {
      "type": "object",
      "required": ["pattern"],
      "additionalProperties": true,
      "properties": {
        "fingerprint":            { "$ref": "#/$defs/Fingerprint" },
        "pattern":                { "type": "string", "minLength": 1 },
        "category":               { "$ref": "#/$defs/Category" },
        "detail":                 { "type": "string" },
        "action":                 { "type": "string" },
        "confidence":             { "type": "number", "minimum": 0, "maximum": 1 },
        "impact":                 { "$ref": "#/$defs/Impact" },
        "status":                 { "$ref": "#/$defs/PatternStatus" },
        "first_seen":             { "$ref": "#/$defs/Timestamp" },
        "last_seen":              { "$ref": "#/$defs/Timestamp" },
        "first_seen_run":         { "type": "integer", "minimum": 0 },
        "last_confirmed_run":     { "type": "integer", "minimum": 0 },
        "supporting_evidence_count": { "type": "integer", "minimum": 0 },
        "applicable_site_types":  {
          "type": "array",
          "items": { "type": "string" }
        },
        "_meta":                  { "type": "object", "additionalProperties": true }
      }
    },

    "Telemetry": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "spans":   { "type": "array", "items": { "type": "object" } },
        "events":  { "type": "array", "items": { "type": "object" } },
        "metrics": { "type": "array", "items": { "$ref": "#/$defs/OtelMetric" } }
      }
    },

    "OtelMetric": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": true,
      "properties": {
        "name":        { "type": "string" },
        "type":        { "type": "string", "enum": ["counter", "gauge", "histogram"] },
        "unit":        { "type": "string", "description": "UCUM where applicable." },
        "url":         { "type": "string", "format": "uri" },
        "data_points": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "value":      { "type": ["number", "integer"] },
              "timestamp":  { "$ref": "#/$defs/Timestamp" },
              "attributes": { "type": "object", "additionalProperties": true }
            }
          }
        }
      }
    },

    "ProjectInfo": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "skills":     { "type": "array", "items": { "$ref": "#/$defs/SkillManifest" } },
        "functions":  { "type": "array", "items": { "type": "object" } },
        "tech_stack": { "type": "object", "additionalProperties": true },
        "api_routes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "method":      { "type": "string" },
              "path":        { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "_meta":      { "type": "object", "additionalProperties": true }
      }
    },

    "SkillManifest": {
      "type": "object",
      "required": ["name", "description"],
      "additionalProperties": true,
      "properties": {
        "name":         { "type": "string", "minLength": 1 },
        "description":  { "type": "string", "minLength": 1 },
        "version":      { "type": "string" },
        "license":      { "type": "string" },
        "allowed_tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "triggers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "compatibility": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "agent_runtimes": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "_meta": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
